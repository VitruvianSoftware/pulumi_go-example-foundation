// ============================================================================
// Dedicated Interconnect — Example
// ============================================================================
//
// This file is an EXAMPLE showing how to provision Dedicated Interconnect
// attachments for on-prem connectivity. This mirrors the Terraform
// foundation's `interconnect.tf.example`.
//
// To activate:
// 1. Rename: interconnect.go.example → interconnect.go
// 2. Update the configuration values below for your environment
// 3. Call deployDedicatedInterconnect() from main.go
// 4. Run `pulumi up` in each environment stack
//
// ============================================================================

package main

import (
	"fmt"

	"github.com/pulumi/pulumi-gcp/sdk/v9/go/gcp/compute"
	"github.com/pulumi/pulumi/sdk/v3/go/pulumi"
)

// InterconnectConfig holds the configuration for Dedicated Interconnect.
type InterconnectConfig struct {
	InterconnectProjectID string
	VPCName               string
	EnvCode               string
	Region1               string
	Region1Router1Name    pulumi.StringInput
	Region1Router2Name    pulumi.StringInput
	Region1Interconnect1  string
	Region1Interconnect1Location string
	Region1Interconnect1CandidateSubnets []string
	Region1Interconnect1VlanTag int
	Region1Interconnect2  string
	Region1Interconnect2Location string
	Region1Interconnect2CandidateSubnets []string
	Region1Interconnect2VlanTag int
	Region2               string
	Region2Router1Name    pulumi.StringInput
	Region2Router2Name    pulumi.StringInput
	Region2Interconnect1  string
	Region2Interconnect1Location string
	Region2Interconnect1CandidateSubnets []string
	Region2Interconnect1VlanTag int
	Region2Interconnect2  string
	Region2Interconnect2Location string
	Region2Interconnect2CandidateSubnets []string
	Region2Interconnect2VlanTag int
	PeerASN  string
	PeerName string
}

// deployDedicatedInterconnect provisions 4x Dedicated Interconnect attachments
// (2 per region, for redundancy) with BGP sessions on existing Cloud Routers.
func deployDedicatedInterconnect(ctx *pulumi.Context, name string, cfg *InterconnectConfig) error {
	// Region 1, Router 1
	_, err := compute.NewInterconnectAttachment(ctx, fmt.Sprintf("%s-r1-attach1", name), &compute.InterconnectAttachmentArgs{
		Project:          pulumi.String(cfg.InterconnectProjectID),
		Region:           pulumi.String(cfg.Region1),
		Router:           cfg.Region1Router1Name,
		Name:             pulumi.Sprintf("vl-%s-%s-r1-a1", cfg.EnvCode, cfg.VPCName),
		Interconnect:     pulumi.String(cfg.Region1Interconnect1),
		CandidateSubnets: pulumi.ToStringArray(cfg.Region1Interconnect1CandidateSubnets),
		VlanTag8021q:     pulumi.Int(cfg.Region1Interconnect1VlanTag),
		Type:             pulumi.String("DEDICATED"),
	})
	if err != nil {
		return err
	}

	// Region 1, Router 2
	_, err = compute.NewInterconnectAttachment(ctx, fmt.Sprintf("%s-r1-attach2", name), &compute.InterconnectAttachmentArgs{
		Project:          pulumi.String(cfg.InterconnectProjectID),
		Region:           pulumi.String(cfg.Region1),
		Router:           cfg.Region1Router2Name,
		Name:             pulumi.Sprintf("vl-%s-%s-r1-a2", cfg.EnvCode, cfg.VPCName),
		Interconnect:     pulumi.String(cfg.Region1Interconnect2),
		CandidateSubnets: pulumi.ToStringArray(cfg.Region1Interconnect2CandidateSubnets),
		VlanTag8021q:     pulumi.Int(cfg.Region1Interconnect2VlanTag),
		Type:             pulumi.String("DEDICATED"),
	})
	if err != nil {
		return err
	}

	// Region 2, Router 1
	_, err = compute.NewInterconnectAttachment(ctx, fmt.Sprintf("%s-r2-attach1", name), &compute.InterconnectAttachmentArgs{
		Project:          pulumi.String(cfg.InterconnectProjectID),
		Region:           pulumi.String(cfg.Region2),
		Router:           cfg.Region2Router1Name,
		Name:             pulumi.Sprintf("vl-%s-%s-r2-a1", cfg.EnvCode, cfg.VPCName),
		Interconnect:     pulumi.String(cfg.Region2Interconnect1),
		CandidateSubnets: pulumi.ToStringArray(cfg.Region2Interconnect1CandidateSubnets),
		VlanTag8021q:     pulumi.Int(cfg.Region2Interconnect1VlanTag),
		Type:             pulumi.String("DEDICATED"),
	})
	if err != nil {
		return err
	}

	// Region 2, Router 2
	_, err = compute.NewInterconnectAttachment(ctx, fmt.Sprintf("%s-r2-attach2", name), &compute.InterconnectAttachmentArgs{
		Project:          pulumi.String(cfg.InterconnectProjectID),
		Region:           pulumi.String(cfg.Region2),
		Router:           cfg.Region2Router2Name,
		Name:             pulumi.Sprintf("vl-%s-%s-r2-a2", cfg.EnvCode, cfg.VPCName),
		Interconnect:     pulumi.String(cfg.Region2Interconnect2),
		CandidateSubnets: pulumi.ToStringArray(cfg.Region2Interconnect2CandidateSubnets),
		VlanTag8021q:     pulumi.Int(cfg.Region2Interconnect2VlanTag),
		Type:             pulumi.String("DEDICATED"),
	})
	return err
}
