// Dedicated Interconnect — Example
// ============================================================================
//
// This file is an EXAMPLE showing how to provision Dedicated Interconnect
// attachments for on-prem connectivity. This mirrors the Terraform
// foundation's `interconnect.tf.example`.
//
// To activate:
// 1. Rename: main.go.example → main.go
// 2. Update the configuration values below for your environment
// 3. Invoke this module from the relevant env's main.go
// 4. Run `pulumi up` in each environment stack
//
// ============================================================================
// PREREQUISITES:
// - Physical Dedicated Interconnect connections must be provisioned
// - Interconnect project ID must be known
// - VLAN tag and candidate subnet values must be planned per environment
// ============================================================================

package dedicated_interconnect

import (
	"fmt"
	"strings"

	"github.com/pulumi/pulumi-gcp/sdk/v9/go/gcp/compute"
	"github.com/pulumi/pulumi/sdk/v3/go/pulumi"
)

type InterconnectConfig struct {
	InterconnectProjectID                pulumi.StringInput
	VpcName                              string
	EnvCode                              string
	Region1                              string
	Region1Router1Name                   pulumi.StringInput
	Region1Router2Name                   pulumi.StringInput
	Region1Interconnect1                 string
	Region1Interconnect1Location         string
	Region1Interconnect1CandidateSubnets []string
	Region1Interconnect1VlanTag          int
	Region1Interconnect2                 string
	Region1Interconnect2Location         string
	Region1Interconnect2CandidateSubnets []string
	Region1Interconnect2VlanTag          int
	Region2                              string
	Region2Router1Name                   pulumi.StringInput
	Region2Router2Name                   pulumi.StringInput
	Region2Interconnect1                 string
	Region2Interconnect1Location         string
	Region2Interconnect1CandidateSubnets []string
	Region2Interconnect1VlanTag          int
	Region2Interconnect2                 string
	Region2Interconnect2Location         string
	Region2Interconnect2CandidateSubnets []string
	Region2Interconnect2VlanTag          int
	PeerAsn                              string
	PeerName                             string
}

func DeployDedicatedInterconnect(ctx *pulumi.Context, name string, config InterconnectConfig, opts ...pulumi.ResourceOption) error {
	// Region 1, Router 1
	r1a1, err := compute.NewInterconnectAttachment(ctx, fmt.Sprintf("%s-r1-attach1", name), &compute.InterconnectAttachmentArgs{
		Project:          config.InterconnectProjectID,
		Region:           pulumi.String(config.Region1),
		Router:           config.Region1Router1Name,
		Name:             pulumi.String(fmt.Sprintf("vl-%s-%s-r1-a1", config.EnvCode, config.VpcName)),
		Interconnect:     pulumi.String(config.Region1Interconnect1),
		CandidateSubnets: pulumi.ToStringArray(config.Region1Interconnect1CandidateSubnets),
		VlanTag8021q:     pulumi.Int(config.Region1Interconnect1VlanTag),
		Type:             pulumi.String("DEDICATED"),
	}, opts...)
	if err != nil {
		return err
	}

	// Region 1, Router 2
	r1a2, err := compute.NewInterconnectAttachment(ctx, fmt.Sprintf("%s-r1-attach2", name), &compute.InterconnectAttachmentArgs{
		Project:          config.InterconnectProjectID,
		Region:           pulumi.String(config.Region1),
		Router:           config.Region1Router2Name,
		Name:             pulumi.String(fmt.Sprintf("vl-%s-%s-r1-a2", config.EnvCode, config.VpcName)),
		Interconnect:     pulumi.String(config.Region1Interconnect2),
		CandidateSubnets: pulumi.ToStringArray(config.Region1Interconnect2CandidateSubnets),
		VlanTag8021q:     pulumi.Int(config.Region1Interconnect2VlanTag),
		Type:             pulumi.String("DEDICATED"),
	}, opts...)
	if err != nil {
		return err
	}

	// Region 2, Router 1
	r2a1, err := compute.NewInterconnectAttachment(ctx, fmt.Sprintf("%s-r2-attach1", name), &compute.InterconnectAttachmentArgs{
		Project:          config.InterconnectProjectID,
		Region:           pulumi.String(config.Region2),
		Router:           config.Region2Router1Name,
		Name:             pulumi.String(fmt.Sprintf("vl-%s-%s-r2-a1", config.EnvCode, config.VpcName)),
		Interconnect:     pulumi.String(config.Region2Interconnect1),
		CandidateSubnets: pulumi.ToStringArray(config.Region2Interconnect1CandidateSubnets),
		VlanTag8021q:     pulumi.Int(config.Region2Interconnect1VlanTag),
		Type:             pulumi.String("DEDICATED"),
	}, opts...)
	if err != nil {
		return err
	}

	// Region 2, Router 2
	r2a2, err := compute.NewInterconnectAttachment(ctx, fmt.Sprintf("%s-r2-attach2", name), &compute.InterconnectAttachmentArgs{
		Project:          config.InterconnectProjectID,
		Region:           pulumi.String(config.Region2),
		Router:           config.Region2Router2Name,
		Name:             pulumi.String(fmt.Sprintf("vl-%s-%s-r2-a2", config.EnvCode, config.VpcName)),
		Interconnect:     pulumi.String(config.Region2Interconnect2),
		CandidateSubnets: pulumi.ToStringArray(config.Region2Interconnect2CandidateSubnets),
		VlanTag8021q:     pulumi.Int(config.Region2Interconnect2VlanTag),
		Type:             pulumi.String("DEDICATED"),
	}, opts...)
	if err != nil {
		return err
	}

	createInterfaceAndPeer := func(rRegion, id string, attach *compute.InterconnectAttachment) error {
		iface, err := compute.NewRouterInterface(ctx, fmt.Sprintf("%s-%s-iface", name, id), &compute.RouterInterfaceArgs{
			Project:                 config.InterconnectProjectID,
			Region:                  attach.Region,
			Router:                  attach.Router,
			Name:                    attach.Name,
			InterconnectAttachment:  attach.Name,
		}, opts...)
		if err != nil {
			return err
		}

		_, err = compute.NewRouterPeer(ctx, fmt.Sprintf("%s-%s-peer", name, id), &compute.RouterPeerArgs{
			Project:                 config.InterconnectProjectID,
			Region:                  attach.Region,
			Router:                  attach.Router,
			Name:                    pulumi.String(fmt.Sprintf("%s-%s", config.PeerName, id)),
			PeerAsn:                 pulumi.Int(parseAsn(config.PeerAsn)),
			PeerIpAddress:           attach.CloudRouterIpAddress.ApplyT(func(ip string) string { return strings.Split(ip, "/")[0] }).(pulumi.StringOutput),
			Interface:               iface.Name,
		}, opts...)
		return err
	}

	if err := createInterfaceAndPeer(config.Region1, "r1a1", r1a1); err != nil {
		return err
	}
	if err := createInterfaceAndPeer(config.Region1, "r1a2", r1a2); err != nil {
		return err
	}
	if err := createInterfaceAndPeer(config.Region2, "r2a1", r2a1); err != nil {
		return err
	}
	if err := createInterfaceAndPeer(config.Region2, "r2a2", r2a2); err != nil {
		return err
	}

	return nil
}

func parseAsn(asn string) int {
	var val int
	fmt.Sscanf(asn, "%d", &val)
	return val
}
