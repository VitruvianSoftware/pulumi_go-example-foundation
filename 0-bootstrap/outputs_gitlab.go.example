/* ----------------------------------------
   Specific to gitlab_bootstrap
  ---------------------------------------- */
// Mirrors: 0-bootstrap/outputs_gitlab.tf.example in the TF foundation.
//
// To use: rename this file outputs_gitlab.go.example → outputs_gitlab.go
// alongside build_gitlab.go (see build_gitlab.go.example) and call
// exportGitLabOutputs(ctx, cicd) from main.go.

package main

import (
	"github.com/pulumi/pulumi/sdk/v3/go/pulumi"
)

// exportGitLabOutputs exports the GitLab-builder-specific outputs.
func exportGitLabOutputs(ctx *pulumi.Context, cicd *CICDProject) {
	// Project where the CI/CD infrastructure for GitLab CI/CD resides.
	ctx.Export("cicd_project_id", cicd.ProjectID)
}
