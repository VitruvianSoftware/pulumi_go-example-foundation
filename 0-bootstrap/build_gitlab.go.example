// ============================================================================
// GitLab CI/CD Provider — Example
// ============================================================================
//
// This file is an EXAMPLE showing how to replace the default GitHub Actions
// CI/CD provider with GitLab CI/CD using Workload Identity Federation.
// This mirrors the Terraform foundation's `build_gitlab.tf.example`.
//
// To use GitLab instead of GitHub Actions:
//
// 1. Rename this file: build_gitlab.go.example → build_gitlab.go
// 2. Remove or rename: build_github.go → build_github.go.bak
// 3. Update main.go:
//    a. Replace the build call (see below)
//    b. Replace the GitHub config fields with GitLab equivalents
//    c. Update the WIF output exports
// 4. Add the required config values to your Pulumi.<stack>.yaml
// 5. Run `pulumi up` to provision the GitLab WIF infrastructure.
//
// ============================================================================
// WHAT THIS CREATES (via modules/gitlab-oidc, mirroring upstream's
// module "gitlab_oidc" in build_gitlab.tf.example):
//
// 1. Workload Identity Pool — "foundation-pool"
// 2. Workload Identity Pool OIDC Provider — "foundation-gl-provider"
//    (issuer: https://gitlab.com)
// 3. SA → WIF attribute bindings — per-SA project_path mappings
// 4. Bootstrap SA gets workloadIdentityPoolAdmin on CI/CD project
// ============================================================================

package main

import (
	"fmt"

	gitlaboidc "foundation-0-bootstrap/modules/gitlab-oidc"

	"github.com/pulumi/pulumi-gcp/sdk/v9/go/gcp/serviceaccount"
	"github.com/pulumi/pulumi/sdk/v3/go/pulumi"
)

// GitLabBuildOutputs holds the outputs from GitLab WIF provisioning.
type GitLabBuildOutputs struct {
	WIFPoolName     pulumi.StringOutput
	WIFProviderName pulumi.StringOutput
}

// deployGitLabBuild provisions the Workload Identity Federation resources
// for GitLab CI/CD. This mirrors the Terraform foundation's build_gitlab.tf.
//
// To use this function, update main.go:
//
//	// Replace:
//	buildOutputs, err := deployGitHubActionsBuild(ctx, cfg, cicd, sas)
//	// With:
//	buildOutputs, err := deployGitLabBuild(ctx, cfg, cicd, sas)
//
// And add these config fields to the Config struct:
//
//	GitLabOwner       string  // GitLab group/user (e.g. "my-org")
//	GitLabRepoBootstrap string
//	GitLabRepoOrg       string
//	GitLabRepoEnv       string
//	GitLabRepoNet       string
//	GitLabRepoProj      string
//	GitLabRepoCICDRunner string  // Repository for CI/CD runner Docker image
func deployGitLabBuild(ctx *pulumi.Context, cfg *Config, cicd *CICDProject, sas map[string]*serviceaccount.Account) (*GitLabBuildOutputs, error) {
	outputs := &GitLabBuildOutputs{}

	// GitLab owner must be set to enable WIF
	// (add GitLabOwner to Config struct and loadConfig)
	gitlabOwner := "" // Replace with: cfg.GitLabOwner
	if gitlabOwner == "" {
		return outputs, nil
	}

	// ========================================================================
	// 1-3. Workload Identity Pool, Provider, and Attribute Bindings
	// ========================================================================
	stageRepos := map[string]string{
		"bootstrap": "", // Replace with: cfg.GitLabRepoBootstrap
		"org":       "", // Replace with: cfg.GitLabRepoOrg
		"env":       "", // Replace with: cfg.GitLabRepoEnv
		"net":       "", // Replace with: cfg.GitLabRepoNet
		"proj":      "", // Replace with: cfg.GitLabRepoProj
	}

	saMappings := make(map[string]gitlaboidc.SAMappingEntry)
	for key, sa := range sas {
		repo := stageRepos[key]
		if repo == "" {
			continue
		}

		saMappings[key] = gitlaboidc.SAMappingEntry{
			SAName:    sa.Name,
			Attribute: fmt.Sprintf("attribute.project_path/%s/%s", gitlabOwner, repo),
		}
	}

	// Mirrors: module "gitlab_oidc" (./modules/gitlab-oidc) in upstream
	// build_gitlab.tf.example.
	gitlabOidc, err := gitlaboidc.NewGitlabOidc(ctx, "gitlab-oidc", &gitlaboidc.GitlabOidcArgs{
		ProjectID:          cicd.ProjectID,
		PoolID:             "foundation-pool",
		ProviderID:         "foundation-gl-provider",
		AttributeCondition: pulumi.String(fmt.Sprintf("assertion.project_path.startsWith('%s/')", gitlabOwner)),
		SAMapping:          saMappings,
		// IssuerURI defaults to https://gitlab.com if not set
	})
	if err != nil {
		return nil, err
	}

	// ========================================================================
	// 4. Bootstrap SA: WIF Pool Admin on CI/CD project
	// The bootstrap SA needs workloadIdentityPoolAdmin to manage the WIF
	// pool during subsequent updates.
	// ========================================================================
	bootstrapSA := sas["bootstrap"]
	if bootstrapSA != nil {
		_, err := serviceaccount.NewIAMMember(ctx, "bootstrap-wif-pool-admin", &serviceaccount.IAMMemberArgs{
			ServiceAccountId: bootstrapSA.Name,
			Role:             pulumi.String("roles/iam.workloadIdentityPoolAdmin"),
			Member: bootstrapSA.Email.ApplyT(func(email string) string {
				return fmt.Sprintf("serviceAccount:%s", email)
			}).(pulumi.StringOutput),
		})
		if err != nil {
			return nil, err
		}
	}

	// ========================================================================
	// 5. Outputs
	// ========================================================================
	outputs.WIFPoolName = gitlabOidc.PoolName
	outputs.WIFProviderName = gitlabOidc.ProviderName

	return outputs, nil
}
