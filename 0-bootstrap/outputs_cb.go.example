/* ----------------------------------------
   Specific to cloudbuild_module
  ---------------------------------------- */
// Mirrors: 0-bootstrap/outputs_cb.tf in the TF foundation.
//
// NOTE on the suffix: upstream ships this file WITHOUT `.example` because its
// default builder is Cloud Build; our port defaults to GitHub Actions, so the
// suffix is inverted here (outputs_github.go is live, this file is the
// example) — matching the build_cb.go.example/build_github.go
// pattern.
//
// To use: rename this file outputs_cb.go.example → outputs_cb.go alongside
// build_cloud_build.go (see build_cb.go.example) and call
// exportCloudBuildOutputs(ctx, cfg, cb) from main.go.

package main

import (
	"github.com/pulumi/pulumi/sdk/v3/go/pulumi"
)

// exportCloudBuildOutputs exports the Cloud-Build-builder-specific outputs,
// mirroring upstream outputs_cb.tf output names.
func exportCloudBuildOutputs(ctx *pulumi.Context, cfg *Config, cb *CloudBuildOutputs) {
	// Project where Cloud Build configuration and the Pulumi container image
	// will reside.
	ctx.Export("cloudbuild_project_id", cb.CloudBuildProjectID)

	// Artifact Registry (AR) Repository created to store Pulumi builder images.
	ctx.Export("cloud_builder_artifact_repo", pulumi.Sprintf(
		"projects/%s/locations/%s/repositories/%s",
		cb.CloudBuildProjectID, cfg.DefaultRegion, cb.ArtifactRepoName))

	// Mirrors: cloud_build_private_worker_pool_id, cloud_build_worker_range_id,
	// cloud_build_worker_peered_ip_range and cloud_build_peered_network_id —
	// from the modules/cb-private-pool component (see build_cb.go.example).
	if cb.PrivatePool != nil {
		ctx.Export("cloud_build_private_worker_pool_id", cb.PrivatePool.PrivateWorkerPoolID)
		ctx.Export("cloud_build_worker_range_id", cb.PrivatePool.WorkerRangeID)
		ctx.Export("cloud_build_worker_peered_ip_range", cb.PrivatePool.WorkerPeeredIPRange)
		ctx.Export("cloud_build_peered_network_id", cb.PrivatePool.PeeredNetworkID)
	}

	// NOT PORTED (documented): upstream also exports
	//   - gcs_bucket_cloudbuild_artifacts / gcs_bucket_cloudbuild_logs —
	//     per-stage buckets created by upstream's tf_workspace
	//     (terraform-google-modules/bootstrap//tf_cloudbuild_workspace)
	//     module, which has no analog in this port's Cloud Build example
	//     (our triggers run from the library cicd component instead).
	//   - csr_repos — Cloud Source Repositories were deprecated by Google
	//     for new customers in June 2024; this port uses GitHub/GitLab as
	//     the source backend, so there are no CSR repos to export.
}
