# Pulumi Configuration for 3-networks-hub-and-spoke/envs/production (production stack).
# The environment identity (production/p) and the spoke CIDR plan are pinned
# in this leaf's main.go; the hub lives in the sibling envs/shared leaf.
config:
  # Required
  foundation-networks-production:spoke_project_id: "prj-p-svpc"
  foundation-networks-production:org_stack_name: "organization/vitruvian/foundation-org-shared/production"

  # Optional
  # foundation-networks-production:region1: "us-central1"
  # foundation-networks-production:region2: "us-west1"
