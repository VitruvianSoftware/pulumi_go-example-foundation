# Pulumi Configuration for 3-networks-hub-and-spoke/envs/nonproduction (production stack).
# The environment identity (nonproduction/n) and the spoke CIDR plan are pinned
# in this leaf's main.go; the hub lives in the sibling envs/shared leaf.
config:
  # Required
  foundation-networks-nonproduction:spoke_project_id: "prj-n-svpc"
  foundation-networks-nonproduction:org_stack_name: "organization/vitruvian/foundation-org-shared/production"

  # Optional
  # foundation-networks-nonproduction:region1: "us-central1"
  # foundation-networks-nonproduction:region2: "us-west1"
