# Pulumi Configuration for 4-projects business_unit_1/production (production stack).
# The environment identity (production) is pinned in this leaf's main.go.
config:
  # Required
  foundation-projects-bu1-production:business_code: "bu1"
  foundation-projects-bu1-production:billing_account: "XXXXXX-XXXXXX-XXXXXX"
  foundation-projects-bu1-production:org_stack_name: "organization/vitruvian/foundation-org-shared/production"
  foundation-projects-bu1-production:env_stack_name: "organization/vitruvian/foundation-environments-production/production"

