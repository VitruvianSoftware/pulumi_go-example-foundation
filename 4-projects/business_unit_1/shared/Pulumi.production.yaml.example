# Pulumi Configuration for 4-projects business_unit_1/shared (production stack).
# The common identity (common/c) is pinned in this leaf's main.go; this leaf
# owns the BU's once-per-BU app-infra pipeline project under the common folder.
config:
  # Required
  foundation-projects-bu1-shared:business_code: "bu1"
  foundation-projects-bu1-shared:billing_account: "XXXXXX-XXXXXX-XXXXXX"
  foundation-projects-bu1-shared:org_stack_name: "organization/vitruvian/foundation-org-shared/production"

  # Optional
  # foundation-projects-bu1-shared:infra_pipeline_enabled: "true"
  # foundation-projects-bu1-shared:project_prefix: "prj"
  # foundation-projects-bu1-shared:budget_amount: "1000"
  # foundation-projects-bu1-shared:api_propagation_seconds: "120"
