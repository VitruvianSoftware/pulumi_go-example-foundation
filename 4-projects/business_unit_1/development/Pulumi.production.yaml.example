# Pulumi Configuration for 4-projects business_unit_1/development (production stack).
# The environment identity (development) is pinned in this leaf's main.go.
config:
  # Required
  foundation-projects-bu1-development:business_code: "bu1"
  foundation-projects-bu1-development:billing_account: "XXXXXX-XXXXXX-XXXXXX"
  foundation-projects-bu1-development:org_stack_name: "organization/vitruvian/foundation-org-shared/production"
  foundation-projects-bu1-development:env_stack_name: "organization/vitruvian/foundation-environments-development/production"

  # Optional
