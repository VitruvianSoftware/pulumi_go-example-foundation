# Pulumi Configuration for 1-org (production stack)
config:
  # Required
  foundation-org-shared:org_id: "YOUR_ORG_ID"
  foundation-org-shared:billing_account: "XXXXXX-XXXXXX-XXXXXX"
  foundation-org-shared:bootstrap_stack_name: "organization/vitruvian/0-bootstrap/production"
  foundation-org-shared:domains_to_allow: "example.com"

  # Optional
  # foundation-org-shared:project_prefix: "prj"
  # foundation-org-shared:folder_prefix: "fldr"
  # foundation-org-shared:default_region: "us-central1"
  # foundation-org-shared:scc_notification_filter: "state=\"ACTIVE\""
  # Opt-in: creates the org's single Access Context Manager policy (default false)
  # foundation-org-shared:create_access_context_manager_policy: "true"
  # foundation-org-shared:parent_folder: ""
